[Script]
# 微信 App 内被屏蔽链接快捷跳转 (weixin110.qq.com)
http-response ^https?:\/\/weixin110\.qq\.com\/cgi-bin\/mmspamsupport-bin\/newredirectconfirmcgi script-path=https://raw.githubusercontent.com/RuCu6/QuanX/main/Scripts/WeiXin_110.js,requires-body=1,timeout=10,tag=微信 App 内被屏蔽链接快捷跳转

# 微信去广告 （mp.weixin.qq.com）
http-response ^https?:\/\/mp\.weixin\.qq\.com\/mp\/getappmsgad requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/RuCu6/QuanX/main/Scripts/WeiXin.js,tag=微信去广告

# 京东历史价格
# http-response ^https?://api\.m\.jd\.com/client\.action\?functionId=(wareBusiness|serverConfig|basicConfig) requires-body=1,script-path=https://raw.githubusercontent.com/yichahucha/surge/master/jd_price.js,tag=京东比价

# 淘宝比价
# http-request ^http://.+/amdc/mobileDispatch requires-body=1,script-path=https://raw.githubusercontent.com/yichahucha/surge/master/tb_price.js,tag=淘宝比价1
# http-response ^https?://trade-acs\.m\.taobao\.com/gw/mtop\.taobao\.detail\.getdetail requires-body=1,script-path=https://raw.githubusercontent.com/yichahucha/surge/master/tb_price.js,tag=淘宝比价2

# 支付宝二维码跳转
http-request ^https?:\/\/weixin110\.qq\.com\/cgi-bin\/mmspamsupport-bin\/newredirectconfirmcgi script-path=https://raw.githubusercontent.com/RuCu6/QuanX/main/Scripts/WeiXin_110.js,tag=支付宝二维码跳转

[MITM]
# hostname = api.m.jd.com, trade-acs.m.taobao.com
hostname = weixin110.qq.com, mp.weixin.qq.com
